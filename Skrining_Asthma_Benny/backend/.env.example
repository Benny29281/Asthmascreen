MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=asthma_db
FLASK_DEBUG=false

# JWT Authentication
# Ganti JWT_SECRET dengan string acak yang panjang dan unik di production!
# Contoh: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=ganti-dengan-secret-yang-aman-dan-panjang
JWT_EXPIRY_HOURS=24
